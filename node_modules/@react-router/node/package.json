{
  "name": "@react-router/node",
  "type": "module",
  "version": "8.0.1",
  "description": "Node.js platform abstractions for React Router",
  "bugs": {
    "url": "https://github.com/remix-run/react-router/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/remix-run/react-router",
    "directory": "packages/react-router-node"
  },
  "license": "MIT",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module-sync": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "wireit": {
    "build": {
      "command": "tsdown",
      "files": [
        "../../pnpm-workspace.yaml",
        "sessions/**",
        "*.ts",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/**"
      ]
    }
  },
  "dependencies": {
    "@remix-run/node-fetch-server": "^0.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "wireit": "0.14.12",
    "react-router": "8.0.1"
  },
  "peerDependencies": {
    "typescript": "^5.1.0 || ^6.0.0",
    "react-router": "8.0.1"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "files": [
    "dist/",
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "wireit",
    "typecheck": "tsc"
  }
}